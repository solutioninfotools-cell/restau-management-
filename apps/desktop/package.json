{
  "name": "@restaurant/desktop",
  "version": "1.0.0",
  "description": "Restaurant Manager - Application Desktop",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && electron .",
    "build:frontend": "cd ../frontend && npm run build && node -e \"const fs=require('fs');fs.rmSync('../desktop/dist',{recursive:true,force:true});fs.cpSync('dist','../desktop/dist',{recursive:true});\"",
    "build": "npm run build:frontend && tsc -p tsconfig.electron.json && electron-builder",
    "build:win": "npm run build:frontend && tsc -p tsconfig.electron.json && electron-builder --win",
    "pack": "npm run build:frontend && tsc -p tsconfig.electron.json && electron-builder --dir"
  },
  "build": {
    "appId": "com.restaurant.manager",
    "productName": "Restaurant Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Restaurant Manager",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.2",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.3",
    "@types/node": "^20.11.20"
  },
  "author": "Restaurant Manager"
}